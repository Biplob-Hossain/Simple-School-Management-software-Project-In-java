import java.time.LocalDate;

public class Student {
    private String id;
    private String name;
    private String fatherName;
    private String motherName;
    private String mobileNumber;
    private String address;
    private String grade;
    private LocalDate admissionDate;
    private double fee;
    private boolean feePaid;

    public Student(String id, String name, String fatherName, String motherName, String mobileNumber, String address, String grade, LocalDate admissionDate, double fee) {
        this.id = id;
        this.name = name;
        this.fatherName = fatherName;
        this.motherName = motherName;
        this.mobileNumber = mobileNumber;
        this.address = address;
        this.grade = grade;
        this.admissionDate = admissionDate;
        this.fee = fee;
        this.feePaid = false;
    }

    public String getId() { return id; }
    public String getName() { return name; }
    public double getFee() { return fee; }
    public boolean isFeePaid() { return feePaid; }
    public void setFeePaid(boolean feePaid) { this.feePaid = feePaid; }

    @Override
    public String toString() {
        return "ID: " + id + ", Name: " + name + ", Grade: " + grade + ", Fee Paid: " + (feePaid ? "Yes" : "No");
    }
}
